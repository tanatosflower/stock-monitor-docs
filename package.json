{
  "name": "stock-monitor-docs",
  "version": "1.0.0",
  "private": true,
  "description": "stock-monitor の解説ドキュメントサイト（VitePress）",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "slides:dev": "slidev",
    "slides:build": "slidev build",
    "slides:export": "slidev export",
    "lint": "npm run lint:text && npm run lint:md",
    "lint:text": "textlint \"docs/**/*.md\"",
    "lint:md": "markdownlint-cli2 \"docs/**/*.md\"",
    "lint:fix": "npm run lint:fix:text ; npm run lint:fix:md",
    "lint:fix:text": "textlint --fix \"docs/**/*.md\"",
    "lint:fix:md": "markdownlint-cli2 --fix \"docs/**/*.md\""
  },
  "devDependencies": {
    "@slidev/cli": "^51.0.0",
    "markdown-it-cjk-friendly": "^2.0.2",
    "markdownlint-cli2": "^0.22.1",
    "mermaid": "^11.4.1",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-preset-japanese": "^10.0.4",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
